# Reference only: the Go process does not automatically load this file.
# Set these values in the API process environment or deployment platform.
# No Supabase secret/service-role key is required for the current JWT/JWKS boundary.
PORT=8080
# Local default; use 0.0.0.0 only when a container/platform must receive external traffic.
HOST=127.0.0.1
WEB_ORIGIN=http://localhost:3000
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key
SUPABASE_JWT_ISSUER=http://127.0.0.1:54321/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated

# Staging-only manual synthetic worker trigger. Keep these server-side and
# unset locally unless running a generated benchmark; never expose or log the
# values. The worker trigger currently rejects real import execution.
WORKER_TRIGGER_SECRET=replace-with-local-only-trigger-secret
SUPABASE_WORKER_IDENTITY=replace-with-staging-worker-identity
SUPABASE_WORKER_PASSWORD=replace-with-staging-worker-password
