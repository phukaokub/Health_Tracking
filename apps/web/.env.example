# Public runtime configuration is visible in the browser bundle. Never put provider,
# Supabase secret/service-role, SMTP, database, or deployment credentials here.
# Copy this file to .env.local for local development; do not commit .env.local.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key
# Keep false outside an explicitly approved local/staging verification window.
NEXT_PUBLIC_IMPORT_UPLOAD_ENABLED=false
